{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSettings": {
    "Issuer": "GymTrackerIssuer",
    "Audience": "GymTrackerAudience",
    "SecretKey": "[SECRET_KEY_MOVED_TO_USER_SECRETS]",
    "Expires": "01:00:00" // 1 hour
  },
}
